# Supabase (public – safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Supabase service role key (server-only, never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Mail Provider: Resend
RESEND_API_KEY=<your-resend-api-key>
FROM_EMAIL=Jazzy <hello@yourdomain.com>

# Welcome recommendation email
# UUID of the album to send to every user right after they confirm their account.
# Find it in your Supabase albums table or via: SELECT album_id FROM albums WHERE title = '...';
WELCOME_ALBUM_ID=<album-uuid>
LANDING_PREVIEW_ALBUM_ID=<your-album-uuid>
